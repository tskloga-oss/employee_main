@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');

body {
    background-color: #f8f9fa;
    font-family: 'Inter', -apple-system, sans-serif; /* Cleaner font */
    margin: 0;
    padding: 20px;
}

h1 {
    color: #2d3436;
    font-weight: 600;
}

/* Table Design to match your goal */
table, .vertical-table {
    margin: 20px auto;
    border-collapse: collapse;
    width: 100%;
    max-width: 1000px;
    background-color: #fdf8e4; /* Cream background */
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

/* Purple Header */
thead tr, 
.vertical-table tr th {
    background-color: #7b1fa2 !important;
    color: white !important;
}

th {
    color: white !important;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 1px;
    padding: 18px 15px;
    text-align: left;
}

.vertical-table th {
    width: 30%;
    border-bottom: 1px solid rgba(255,255,255,0.1);
}

td {
    padding: 15px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    color: #4d4d4d;
    font-size: 0.9rem;
    vertical-align: middle;
}

/* FIX: Icons in a single line */
.actions-container {
    display: flex;
    gap: 12px; /* Space between icons */
    align-items: center;
    white-space: nowrap; /* Prevents wrapping to second line */
}

.actions-container a {
    text-decoration: none;
    font-size: 1.1rem;
    transition: transform 0.2s;
}

.actions-container a:hover {
    transform: scale(1.2);
}

.fa-eye { color: #7b1fa2; }
.fa-edit { color: #0984e3; }
.fa-trash { color: #d63031; }

/* Add Employee Button */
.add-btn {
    background-color: #7b1fa2;
    color: white !important;
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
}


/* --- Form Card Styling --- */
.form-container {
    max-width: 600px;
    margin: 40px auto;
    background-color: #fdf8e4; /* Your Cream Background */
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    text-align: left; /* Align labels to the left */
}

.form-container h1 {
    margin-top: 0;
    color: #333;
    font-size: 1.5rem;
    border-bottom: 2px solid #7b1fa2;
    padding-bottom: 10px;
    margin-bottom: 25px;
}

/* --- Targeting Django's {{ form.as_p }} --- */
.form-body p {
    margin-bottom: 20px;
    display: flex;
    flex-direction: column; /* Label on top, input below */
}

.form-body label {
    font-weight: 600;
    color: #7b1fa2; /* Purple Labels */
    margin-bottom: 8px;
    text-transform: uppercase;
    font-size: 0.8rem;
}

.form-body input, 
.form-body select, 
.form-body textarea {
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    background-color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
}

.form-body input:focus {
    outline: none;
    border-color: #7b1fa2;
    box-shadow: 0 0 5px rgba(123, 31, 162, 0.2);
}

/* --- Buttons --- */
.form-footer {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
}

.submit-btn {
    background-color: #7b1fa2;
    color: white;
    padding: 12px 25px;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    cursor: pointer;
    transition: background 0.3s;
}

.submit-btn:hover {
    background-color: #5e1684;
}

.cancel-link {
    color: #666;
    text-decoration: none;
    font-size: 0.9rem;
}

.cancel-link:hover {
    text-decoration: underline;
}

/* --- Alerts --- */
.alert {
    background-color: #d1e7dd;
    color: #0f5132;
    padding: 15px;
    border-radius: 6px;
    margin-bottom: 20px;
    border: 1px solid #badbcc;
}